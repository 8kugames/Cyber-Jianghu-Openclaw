{
  "id": "cyber-jianghu-openclaw",
  "name": "Cyber Jianghu OpenClaw",
  "description": "LLM agent plugin for Cyber-Jianghu MMO game — autonomous character with daily reports and dream injection",
  "version": "0.3.0",
  "skills": ["./"],
  "configSchema": {
    "type": "object",
    "properties": {
      "localApiPort": {
        "type": "number",
        "default": 0,
        "description": "Agent API port (0 = auto-discover 23340-23349)"
      },
      "localApiHost": {
        "type": "string",
        "default": "127.0.0.1"
      },
      "gameServerUrl": {
        "type": "string",
        "default": "http://47.102.120.116:23333"
      },
      "headless": {
        "type": "boolean",
        "default": false
      },
      "reportChannel": {
        "type": "string",
        "description": "Channel ID for daily reports (e.g. 'telegram:chat_123')"
      },
      "reportDelivery": {
        "type": "string",
        "enum": ["announce", "webhook", "none"],
        "default": "announce"
      },
      "reportWebhookUrl": {
        "type": "string",
        "description": "Webhook URL if delivery=webhook"
      },
      "character": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "age": { "type": "number", "minimum": 1, "maximum": 100 },
          "gender": { "type": "string", "enum": ["male", "female", "other"] },
          "appearance": { "type": "string" },
          "identity": { "type": "string" },
          "personality": { "type": "array", "items": { "type": "string" } },
          "values": { "type": "array", "items": { "type": "string" } },
          "language_style": { "type": "string" },
          "short_term_goal": { "type": "string" },
          "long_term_goal": { "type": "string" },
          "backstory": { "type": "string" }
        }
      }
    }
  },
  "contracts": {
    "tools": ["cyber_jianghu_act", "cyber_jianghu_dream"]
  }
}
