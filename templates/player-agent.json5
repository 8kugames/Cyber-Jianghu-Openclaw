// ============================================================================
// OpenClaw Agent Configuration: Player Agent Template
// ============================================================================
//
// Cyber-Jianghu v0.3.0 — LLM Provider + User Communication Bridge
//
// Architecture:
//   User (IM) ↕ OpenClaw (Brain) ←WS→ Agent (Body/Rust) ←WS→ Game Server
//
// The OpenClaw plugin:
//   - Connects to Rust Agent via WebSocket for tick/intent protocol
//   - Registers act/dream tools for the LLM
//   - Pushes daily narrative reports to user's IM channel
//   - Allows user "dream injection" for limited intervention
//
// Usage:
//   cp templates/player-agent.json5 ~/.openclaw/agents/my-agent.json5
// ============================================================================

{
  // Agent 基本信息
  name: "cyber-jianghu-player",
  description: "Cyber-Jianghu player agent driven by OpenClaw",

  // 工作区配置
  agents: {
    defaults: {
      workspace: "~/.openclaw/cyber-jianghu-openclaw-agents/cyber-jianghu-player",

      // Cron: 定时触发决策，先读取最新 WS 上下文再提交动作
      cron: [
        {
          name: "game-tick-check",
          expression: "*/10 * * * * *", // 每 10 秒检查
          prompt: `检查并响应游戏状态。

第一步必须先调用 cyber_jianghu_context 获取最新 Tick 上下文。

**CRITICAL**: 你必须调用 cyber_jianghu_act 工具来提交动作。没有例外。

决策流程:
1. 调用 cyber_jianghu_context 获取当前状态
2. 根据你的人设和当前情况思考
3. 调用 cyber_jianghu_act 工具提交动作

如果 cyber_jianghu_context 返回 unavailable，可以跳过本次决策。`,
          session: "main",
          enabled: true,
        },
      ],

      heartbeat: {
        every: "0m",
        enabled: false,
      },

      model: "claude/claude-sonnet-4-20250514",
      timeoutSeconds: 45,
    },
  },

  // Hook 配置 - 使用新的 bootstrap hook
  hooks: {
    "agent:bootstrap": "hooks/bootstrap",
  },

  // 工具配置
  tools: {
    required: ["cyber_jianghu_context", "cyber_jianghu_act"],
    allow: [
      "cyber_jianghu_context",
      "cyber_jianghu_act",
      "cyber_jianghu_dream",
      "read",
      "write",
    ],
  },

  // 沙箱配置
  sandbox: {
    enabled: false,
    workspaceRoot: "~/.openclaw/sandboxes",
    privilegeMode: "restricted",
  },
}
