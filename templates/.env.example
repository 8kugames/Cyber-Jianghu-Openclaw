# Cyber-Jianghu OpenClaw Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# ============================================================================
# Agent Connection
# ============================================================================

# Agent HTTP API host (default: host.docker.internal for Docker)
DOCKER_AGENT_HOST=host.docker.internal

# ============================================================================
# Character Configuration (Required for Headless Mode)
# ============================================================================

# Character name (required)
CHARACTER_NAME=

# Character age 1-100 (required)
CHARACTER_AGE=

# Character gender: male, female, other (required)
CHARACTER_GENDER=

# Character identity/role (optional)
CHARACTER_IDENTITY=

# Character personality traits, comma-separated (optional)
# Example: 豪爽,正直,勇敢
CHARACTER_PERSONALITY=

# Character core values, comma-separated (optional)
# Example: 侠义,自由,公道
CHARACTER_VALUES=

# Character appearance description (optional)
CHARACTER_APPEARANCE=

# Character speaking style (optional)
CHARACTER_LANGUAGE_STYLE=

# Character goals, comma-separated (optional)
# Example: 成为天下第一剑客,找到失散的师父
CHARACTER_GOALS=

# Character backstory (optional)
CHARACTER_BACKSTORY=

# ============================================================================
# Report Configuration
# ============================================================================

# Delivery mode: announce (push to IM), webhook (HTTP POST), none
REPORT_DELIVERY=announce

# Channel ID for daily reports (e.g. telegram:chat_123, discord:channel_456)
# REPORT_CHANNEL=

# Webhook URL (only needed if REPORT_DELIVERY=webhook)
# REPORT_WEBHOOK_URL=https://your-webhook.com/reports

# ============================================================================
# Runtime Mode
# ============================================================================

# Run in headless mode (skip interactive prompts)
# Set to true for Docker/CI environments
HEADLESS=true
