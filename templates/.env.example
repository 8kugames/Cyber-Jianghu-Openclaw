# Cyber-Jianghu OpenClaw Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# ============================================================================
# Agent Connection
# ============================================================================

# Agent HTTP API host (default: host.docker.internal for Docker)
DOCKER_AGENT_HOST=host.docker.internal

# Player Agent API URL (for Observer Agent to connect)
# PLAYER_API_URL=http://player-agent:23340

# ============================================================================
# Character Configuration (Required for Headless Mode)
# ============================================================================

# Character name (required)
CHARACTER_NAME=

# Character age 1-100 (required)
CHARACTER_AGE=

# Character gender: male, female, other (required)
CHARACTER_GENDER=

# Character identity/role (optional)
CHARACTER_IDENTITY=

# Character personality traits, comma-separated (optional)
# Example: 豪爽,正直,勇敢
CHARACTER_PERSONALITY=

# Character core values, comma-separated (optional)
# Example: 侠义,自由,公道
CHARACTER_VALUES=

# ============================================================================
# Observer Agent Configuration
# ============================================================================

# Enable observer mode (default: false)
OBSERVER_MODE=false

# Polling interval for pending reviews in milliseconds (default: 5000)
OBSERVER_POLL_INTERVAL=5000

# ============================================================================
# Report Configuration
# ============================================================================

# Webhook URL for report push notifications (optional)
# REPORT_WEBHOOK_URL=https://your-webhook.com/reports

# ============================================================================
# Runtime Mode
# ============================================================================

# Run in headless mode (skip interactive prompts)
# Set to true for Docker/CI environments
HEADLESS=true
