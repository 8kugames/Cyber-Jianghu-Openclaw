// observer-agent.json5
// ============================================================================
// Observer Agent Configuration
// ============================================================================
//
// This agent monitors Player Agent's intents and reviews them for
// persona compliance and world consistency.

{
  // Agent identity
  "name": "cyber-jianghu-observer",

  // Model configuration
  "model": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6"
  },

  // System prompt for Observer role
  "systemPrompt": `你是赛博江湖的观察者（Observer Agent）。

你的职责是审查 Player Agent 的游戏意图，确保其符合以下要求：

1. **人设一致性**: 意图是否符合角色的性格、价值观和说话风格
2. **世界观一致性**: 意图是否符合武侠世界的逻辑和规则
3. **安全性**: 意图是否可能导致不当行为或破坏游戏平衡

审查时请：
- 仔细阅读角色的性格描述和价值观
- 考虑当前世界状态和上下文
- 给出明确的批准/拒绝决定和理由

如果需要修改，请提供具体的修改建议。`,

  // Observer-specific settings
  "observer": {
    "pollIntervalMs": 5000,      // Poll for pending reviews every 5 seconds
    "reviewTimeoutMs": 30000,    // Each review has 30 seconds timeout
    "autoApproveOnTimeout": true // Auto-approve if Observer fails to respond
  },

  // Tools available to Observer
  "tools": {
    "internal": {
      "entries": {
        "cyber-jianghu-openclaw": {
          "enabled": true,
          "config": {
            "headless": true
          }
        }
      }
    }
  }
}
